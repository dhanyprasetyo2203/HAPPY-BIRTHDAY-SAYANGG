// TRANSLATIONS (existing)...

// ========== NEW FEATURES: DARK MODE ==========
function initDarkMode() {
    const toggle = document.getElementById('darkToggle');
    const html = document.documentElement;
    
    // Load saved theme
    const savedTheme = localStorage.getItem('theme') || 'light';
    html.setAttribute('data-theme', savedTheme);
    toggle.querySelector('i').className = savedTheme === 'dark' ? 'fas fa-sun' : 'fas fa-moon';
    
    toggle.addEventListener('click', () => {
        const isDark = html.getAttribute('data-theme') === 'dark';
        const newTheme = isDark ? 'light' : 'dark';
        html.setAttribute('data-theme', newTheme);
        localStorage.setItem('theme', newTheme);
        toggle.querySelector('i').className = newTheme === 'dark' ? 'fas fa-sun' : 'fas fa-moon';
        showToast(`Mode ${newTheme === 'dark' ? 'Gelap' : 'Terang'} diaktifkan`);
    });
}

// ========== STATS COUNTERS (NEW) ==========
function animateCounters() {
    const statsSection = document.getElementById('stats');
    if (!statsSection) return;
    
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const items = entry.target.querySelectorAll('.stat-item');
                items.forEach(item => animateCounter(item));
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.5 });
    
    observer.observe(statsSection);
}

function animateCounter(item) {
    const target = parseInt(item.dataset.target);
    const numberEl = item.querySelector('.stat-number');
    let current = 0;
    const increment = target / 50;
    const timer = setInterval(() => {
        current += increment;
        if (current >= target) {
            current = target;
            clearInterval(timer);
        }
        numberEl.textContent = Math.floor(current).toLocaleString('id-ID') + (target >= 1000 ? 'k' : '');
    }, 30);
}

// ========== TESTIMONIAL SLIDER (NEW) ==========
function initTestimonials() {
    const container = document.getElementById('testimonialSlider');
    if (!container) return;
    
    container.innerHTML = testimonialsData.map(test => `
        <div class="swiper-slide">
            <div class="testimonial-card">
                <div class="testimonial-avatar">${test.avatar}</div>
                <div class="testimonial-text">"${test.text}"</div>
                <div class="testimonial-author">– ${test.name}</div>
                <div class="stars">★★★★★</div>
            </div>
        </div>
    `).join('');
    
    swiper = new Swiper('.testimonial-swiper', {
        slidesPerView: 1,
        spaceBetween: 30,
        loop: true,
        autoplay: { delay: 5000 },
        pagination: { el: '.swiper-pagination', clickable: true },
        navigation: {
            nextEl: '.swiper-button-next',
            prevEl: '.swiper-button-prev',
        },
        breakpoints: {
            768: { slidesPerView: 2 },
            1024: { slidesPerView: 3 }
        }
    });
}

// ========== FAQ ACCORDION (NEW) ==========
function initFAQ() {
    document.querySelectorAll('.faq-question').forEach(question => {
        question.addEventListener('click', () => {
            const item = question.parentElement;
            const isActive = item.classList.contains('active');
            
            // Close all
            document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('active'));
            
            // Toggle current
            if (!isActive) {
                item.classList.add('active');
            }
        });
    });
}

// ========== LIGHTBOX (NEW) ==========
function initLightbox() {
    const modal = document.getElementById('carModal');
    const closeBtn = document.querySelector('.close-lightbox');
    const bookBtn = document.getElementById('lightboxBookBtn');
    
    // Close handlers
    closeBtn.addEventListener('click', () => modal.classList.remove('active'));
    modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.classList.remove('active');
    });
    
    // Book from lightbox
    bookBtn.addEventListener('click', () => {
        selectCar(currentSelectedCar.id);
        modal.classList.remove('active');
        document.getElementById('booking').scrollIntoView({ behavior: 'smooth' });
    });
    
    window.selectCarForLightbox = function(car) {
        document.getElementById('lightboxImage').innerHTML = `<img src="${car.image}" alt="${car.name}">`;
        document.getElementById('lightboxTitle').textContent = car.name;
        document.getElementById('lightboxPrice').innerHTML = `Rp ${car.price12.toLocaleString('id-ID')} <span>/12 jam</span>`;
        document.getElementById('lightboxCapacity').innerHTML = `<i class="fas fa-users"></i> ${car.capacity} penumpang + Driver`;
        currentSelectedCar = car;
        updatePriceCalculation();
        modal.classList.add('active');
    };
}

// ========== PROMO CODE (NEW) ==========
function initPromo() {
    const promoInput = document.getElementById('promoCode');
    const statusEl = document.getElementById('promoStatus');
    
    if (!promoInput) return;
    
    promoInput.addEventListener('input', debounce(validatePromo, 500));
    
    function validatePromo() {
        const code = promoInput.value.toUpperCase().trim();
        statusEl.classList.remove('valid', 'invalid');
        statusEl.style.display = 'none';
        
        if (!code) {
            promoDiscount = 0;
            updatePriceCalculation();
            return;
        }
        
        if (promoCodes[code]) {
            promoDiscount = promoCodes[code];
            statusEl.textContent = `✅ Diskon ${Math.round(promoDiscount*100)}% diterapkan!`;
            statusEl.classList.add('valid');
        } else {
            statusEl.textContent = '❌ Kode promo tidak valid';
            statusEl.classList.add('invalid');
            promoDiscount = 0;
        }
        statusEl.style.display = 'block';
        updatePriceCalculation();
    }
}

// ========== FORM AUTOSAVE (NEW) ==========
function initFormAutosave() {
    const form = document.getElementById('bookingForm');
    if (!form) return;
    
    // Load saved data
    Object.keys(formData).forEach(key => {
        const el = document.getElementById(key);
        if (el) el.value = formData[key];
    });
    
    // Auto-save on change
    form.addEventListener('input', debounce(() => {
        const data = {};
        form.querySelectorAll('input, select, textarea').forEach(el => {
            data[el.id] = el.value;
        });
        localStorage.setItem('bataviaForm', JSON.stringify(data));
    }, 1000));
}

// Debounce utility
function debounce(func, wait) {
    let timeout;
    return function executedFunction(...args) {
        const later = () => {
            clearTimeout(timeout);
            func(...args);
        };
        clearTimeout(timeout);
        timeout = setTimeout(later, wait);
    };
}

// ========== ENHANCED PRICE CALC ==========
function updatePriceCalculation() {
    const durasi = currentDurasi;
    let totalPrice = getPriceByDuration(currentSelectedCar, durasi);
    const dp = Math.round(totalPrice * 0.3 * (1 - promoDiscount));
    const sisa = totalPrice - dp;
    
    document.getElementById("selectedCarName").textContent = currentSelectedCar.name;
    document.getElementById("summaryDurasi").textContent = durasi === "6" ? "6 jam" : (durasi === "12" ? "12 jam" : "24 jam (Harian)");
    document.getElementById("promoDiscount").textContent = promoDiscount > 0 ? `-${Math.round(promoDiscount*100)}%` : 'Rp 0';
    document.getElementById("totalHarga").innerHTML = `Rp ${totalPrice.toLocaleString('id-ID')}`;
    document.getElementById("dpAmount").innerHTML = `Rp ${dp.toLocaleString('id-ID')}`;
    document.getElementById("sisaBayar").innerHTML = `Rp ${sisa.toLocaleString('id-ID')}`;
    
    currentPrice = totalPrice;
}

// ========== ALL EXISTING FUNCTIONS (ENHANCED) ==========
