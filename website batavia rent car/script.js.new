// Add lightbox to car cards:

function renderCars() {
    const container = document.getElementById("cars-grid");
    container.innerHTML = carsData.map((car, index) => `
        <div class="car-card" data-aos="fade-up" data-aos-delay="${index * 100}">
            <div class="car-image" onclick="window.selectCarForLightbox(${JSON.stringify(car)})">
                <img src="${car.image}" alt="${car.name}" loading="lazy">
            </div>
            <div class="car-info">
                <h3>${car.name}</h3>
                <div class="price">Rp ${car.price12.toLocaleString('id-ID')} <span>/12 jam</span></div>
                <div class="capacity"><i class="fas fa-users"></i> ${car.capacity} penumpang | <i class="fas fa-user-check"></i> + Driver</div>
                <button class="btn-primary" onclick="selectCar(${car.id})">
                    <i class="fas fa-shopping-cart"></i> Pilih Mobil Ini
                </button>
            </div>
        </div>
    `).join('');
}

